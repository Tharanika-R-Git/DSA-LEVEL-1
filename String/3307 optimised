class Solution {
    public char kthCharacter(long k, int[] operations) {
        int n =  operations.length;
        long shift =0;
        for(int i = n-1;i>=0;i--){
            long half = (i>=60)?Long.MAX_VALUE:1L<<i;
            if(k>half){
                k-=half;
                if(operations[i]==1){
                    shift++;
                }
            }
        }
        return (char)((shift%26)+'a');
    }
}
